# Fase A (local): valores de `supabase status` tras `supabase start`.
# Fase B (prod): reemplazar TODO por las llaves del proyecto Supabase Pro.
# NUNCA copiar las llaves locales a producción — son de demo, iguales para
# cualquiera que corra `supabase start` en su máquina.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL fija para construir links de invitación (nunca derivada del Host header).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vacío en local => el link de invitación se imprime en consola (solo dev).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Protege /api/cron/alerts (header Authorization: Bearer <valor>).
# Generar uno propio: openssl rand -hex 24
CRON_SECRET=

# Rate limiting (login/subida/descarga). Vacío en local => fallback en
# memoria de un solo proceso (sirve para probar la lógica, NO limita nada de
# verdad en producción con múltiples instancias). Obligatorias en Cloudflare:
# crea una base gratis en https://console.upstash.com (Redis > REST API).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cifrado app-level de la cédula del representante legal / beneficiario final
# (AES-256-GCM, lib/security/field-encryption.ts). La clave NUNCA vive en la
# BD ni en el repo — solo aquí (local) o como secret de Cloudflare (prod).
# Formato: "version:clave_base64,version:clave_base64" (varias versiones =
# rotación en curso).
# Generar una clave: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEYS=
FIELD_ENCRYPTION_ACTIVE_VERSION=
